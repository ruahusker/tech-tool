    },
    {
      "id": "win-repair-systemfiles",
      "path": "windows/Repair-SystemFiles.ps1",
      "platform": "windows",
      "category": "repair",
      "summary": "DISM + SFC. Default diagnoses only; -Repair runs RestoreHealth + scannow (15-60 min).",
      "use_when": [
        "Windows Update failures",
        "missing DLL / corrupt system file errors",
        "start menu/explorer corruption",
        "post-malware cleanup"
      ],
      "admin": true,
      "destructive": false,
      "runtime_seconds": 1800,
      "args": [
        {
          "name": "-Repair",
          "required": false,
          "desc": "actually repair instead of diagnose"
        }
      ],
      "title": "Repair System Files"
    },
    {
      "id": "win-triage-snapshot",
      "path": "windows/Invoke-TriageSnapshot.ps1",
      "platform": "windows",
      "category": "triage",
      "summary": "Runs all read-only diagnostics + raw extras (ipconfig, netstat, drivers, tasks), saves+zips to USB collections.",
      "use_when": [
        "unknown problem - collect everything first",
        "intermittent issue to analyze later",
        "gather evidence for the AI to analyze"
      ],
      "admin": "optional (more data with it)",
      "destructive": false,
      "runtime_seconds": 240,
      "args": [
        {
          "name": "-OutDir",
          "required": false
        }
      ],
      "title": "Full Triage Snapshot"
    },
