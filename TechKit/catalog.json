    {
      "id": "mac-remove-inactive-users",
      "path": "macos/remove_inactive_users.sh",
      "platform": "macos",
      "category": "accounts",
      "summary": "Disable (default) or delete local users with no login in N days. Dry-run unless --force (sudo). Admin accounts are NEVER touched (no override). Also protects the current user.",
      "use_when": [
        "clean up shared Mac accounts",
        "remove departed-user accounts"
      ],
      "admin": true,
      "destructive": true,
      "dry_run_default": true,
      "runtime_seconds": 15,
      "args": [
        {
          "name": "days",
          "required": false,
          "default": 90,
          "positional": true
        },
        {
          "name": "--delete",
          "required": false
        },
        {
          "name": "--remove-home",
          "required": false
        },
        {
          "name": "--include-unknown",
          "required": false
        },
