{
  "techkit_version": "1.0",
  "description": "Technician script library. Every script is read-only unless 'destructive' is true. Destructive scripts dry-run by default and require an explicit force flag to act.",
  "conventions": {
    "windows": "PowerShell 5.1+. Run: powershell -ExecutionPolicy Bypass -File <script> [params]",
    "macos": "bash 3.2+. Run: bash <script> [args]. Scripts needing root say so and degrade gracefully without it.",
    "collections": "Evidence/output bundles are written to TechKit/collections/ on the USB drive."
  },
  "scripts": [
    {
      "id": "win-system-report",
      "path": "windows/Get-SystemReport.ps1",
      "platform": "windows",
      "category": "sysinfo",
      "summary": "One-page overview: OS, hardware, BIOS/serial, RAM slots, uptime, domain join, disk summary, pending reboot.",
      "use_when": [
        "first look at any machine",
        "need serial/model/specs",
        "is it domain joined",
        "was it rebooted recently"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 10,
      "args": [
        {
          "name": "-OutFile",
          "required": false,
          "desc": "also save report to a text file"
        }
      ],
      "title": "System Report"
    },
    {
      "id": "win-disk-health",
      "path": "windows/Get-DiskHealth.ps1",
      "platform": "windows",
      "category": "storage",
      "summary": "SMART status, volume health, free space, dirty bit, disk errors from the System event log.",
      "use_when": [
        "slow computer",
        "freezing",
        "clicking noises",
        "boot failures",
        "file corruption"
      ],
      "admin": "optional (SMART/wear data needs it)",
      "destructive": false,
      "runtime_seconds": 15,
      "args": [
        {
          "name": "-EventHours",
          "required": false,
          "default": 168,
          "desc": "event log look-back window"
        }
      ],
      "title": "Disk Health"
    },
    {
      "id": "win-top-processes",
      "path": "windows/Get-TopProcesses.ps1",
      "platform": "windows",
      "category": "performance",
      "summary": "Top CPU and memory consumers (sampled), memory/pagefile pressure.",
      "use_when": [
        "computer is slow right now",
        "fan always running",
        "out of memory errors"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 10,
      "args": [
        {
          "name": "-SampleSeconds",
          "required": false,
          "default": 5
        },
        {
          "name": "-Top",
          "required": false,
          "default": 12
        }
      ],
      "title": "Resource Usage"
    },
    {
      "id": "win-startup-items",
      "path": "windows/Get-StartupItems.ps1",
      "platform": "windows",
      "category": "performance",
      "summary": "Run keys, startup folders, logon scheduled tasks, auto-services that are stopped, WMI startup inventory.",
      "use_when": [
        "slow startup",
        "popups at login",
        "suspected unwanted software persistence",
        "service won't start"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 10,
      "args": [],
      "title": "Startup Programs"
    },
    {
      "id": "win-network-diagnostics",
      "path": "windows/Get-NetworkDiagnostics.ps1",
      "platform": "windows",
      "category": "network",
      "summary": "Layered check: adapters, IP/DHCP, gateway ping, internet by IP, DNS, HTTP/captive portal, proxy, Wi-Fi signal.",
      "use_when": [
        "no internet",
        "intermittent connection",
        "only some sites work",
        "slow network"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 25,
      "args": [],
      "title": "Network Diagnostics"
    },
    {
      "id": "win-test-connectivity",
      "path": "windows/Test-Connectivity.ps1",
      "platform": "windows",
      "category": "network",
      "summary": "Targeted test to one host: DNS, ping, TCP port, optional traceroute.",
      "use_when": [
        "can't reach a specific server/printer/share",
        "app cannot connect to backend"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 20,
      "args": [
        {
          "name": "-Target",
          "required": true,
          "desc": "hostname or IP"
        },
        {
          "name": "-Port",
          "required": false,
          "desc": "TCP port the app uses"
        },
        {
          "name": "-TraceRoute",
          "required": false
        }
      ],
      "title": "Connectivity Test"
    },
    {
      "id": "win-event-summary",
      "path": "windows/Get-EventLogSummary.ps1",
      "platform": "windows",
      "category": "logs",
      "summary": "Groups recent System/Application errors by source; lists distinct errors; flags BSODs, app crashes, dirty shutdowns.",
      "use_when": [
        "random crashes/reboots",
        "blue screens",
        "app keeps crashing",
        "what went wrong yesterday"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 30,
      "args": [
        {
          "name": "-Hours",
          "required": false,
          "default": 48
        },
        {
          "name": "-Top",
          "required": false,
          "default": 15
        }
      ],
      "title": "Event Log Summary"
    },
    {
      "id": "win-export-eventlogs",
      "path": "windows/Export-EventLogs.ps1",
      "platform": "windows",
      "category": "logs",
      "summary": "Export System/Application(/Security if admin) .evtx plus systeminfo/ipconfig/hotfixes to the USB collections folder.",
      "use_when": [
        "need to take evidence away for analysis",
        "escalating to another team"
      ],
      "admin": "optional (Security log needs it)",
      "destructive": false,
      "runtime_seconds": 40,
      "args": [
        {
          "name": "-Destination",
          "required": false,
          "desc": "output folder; defaults to USB collections"
        }
      ],
      "title": "Export Event Logs"
    },
    {
      "id": "win-update-status",
      "path": "windows/Get-WindowsUpdateStatus.ps1",
      "platform": "windows",
      "category": "updates",
      "summary": "Build/UBR, recent hotfixes, WU agent history with failures flagged, WU services, pending reboot, free space.",
      "use_when": [
        "updates keep failing",
        "is this machine patched",
        "stuck on old build"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 20,
      "args": [],
      "title": "Update Status"
    },
    {
      "id": "win-repair-windowsupdate",
      "path": "windows/Repair-WindowsUpdate.ps1",
      "platform": "windows",
      "category": "updates",
      "title": "Repair Windows Update",
      "summary": "Resets Windows Update: stops wuauserv/BITS/cryptsvc/msiserver, renames SoftwareDistribution + catroot2, clears the BITS queue, restarts services, triggers a fresh scan. Optional DISM+SFC and deep reset.",
      "use_when": [
        "windows update stuck or failing",
        "update error codes",
        "updates won't download or install",
        "0x8024 / 0x80070 errors"
      ],
      "admin": true,
      "destructive": true,
      "dry_run_default": true,
      "runtime_seconds": 120,
      "args": [
        {
          "name": "-Force",
          "required": false,
          "desc": "actually apply; otherwise dry-run preview"
        },
        {
          "name": "-RepairImage",
          "required": false,
          "desc": "also run DISM RestoreHealth + SFC (15-45 min)"
        },
        {
          "name": "-DeepReset",
          "required": false,
          "desc": "also re-register WU/BITS DLLs + reset Winsock (reboot after)"
        },
        {
          "name": "-SkipCatroot2",
          "required": false,
          "desc": "leave catroot2 untouched"
        }
      ]
    },
    {
      "id": "win-security-status",
      "path": "windows/Get-SecurityStatus.ps1",
      "platform": "windows",
      "category": "security",
      "summary": "AV state, firewall profiles, BitLocker, UAC, local admins, RDP/WinRM, SMBv1, SecureBoot/TPM.",
      "use_when": [
        "security audit",
        "suspected infection",
        "compliance check",
        "before handing machine back"
      ],
      "admin": "optional (BitLocker/TPM/SMB-feature detail)",
      "destructive": false,
      "runtime_seconds": 20,
      "args": [],
      "title": "Security Check"
    },
    {
      "id": "win-user-report",
      "path": "windows/Get-UserAccountReport.ps1",
      "platform": "windows",
      "category": "accounts",
      "summary": "Local users with last logon and password age, who is logged on, profile folder sizes, Administrators members.",
      "use_when": [
        "account audit",
        "before deleting/disabling users",
        "who uses this machine"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 60,
      "args": [
        {
          "name": "-SkipProfileSizes",
          "required": false,
          "desc": "skip the slow folder measuring"
        }
      ],
      "title": "User Accounts"
    },
    {
      "id": "win-remove-inactive-users",
      "path": "windows/Remove-InactiveUsers.ps1",
      "platform": "windows",
      "category": "accounts",
      "summary": "Disable (default) or delete local users inactive N days. Dry-run unless -Force. Admin accounts are NEVER touched (no override). Also protects built-ins and the current user.",
      "use_when": [
        "clean up shared/lab machine accounts",
        "remove departed-user local accounts"
      ],
      "admin": true,
      "destructive": true,
      "dry_run_default": true,
      "runtime_seconds": 15,
      "args": [
        {
          "name": "-DaysInactive",
          "required": false,
          "default": 90
        },
        {
          "name": "-Delete",
          "required": false,
          "desc": "delete instead of disable"
        },
        {
          "name": "-RemoveProfile",
          "required": false,
          "desc": "with -Delete, also remove profile folder"
        },
        {
          "name": "-IncludeNeverLoggedOn",
          "required": false
        },
        {
          "name": "-Exclude",
          "required": false,
          "desc": "comma-separated account names to protect"
        },
        {
          "name": "-Force",
          "required": false,
          "desc": "actually apply; otherwise dry run"
        }
      ],
      "title": "Remove Inactive Users"
    },
    {
      "id": "win-find-large-files",
      "path": "windows/Find-LargeFiles.ps1",
      "platform": "windows",
      "category": "storage",
      "summary": "Largest files, first-level folder sizes, known hogs (WU cache, hiberfil, Windows.old, recycle bin).",
      "use_when": [
        "disk full",
        "what is using all the space"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 180,
      "args": [
        {
          "name": "-Path",
          "required": false,
          "default": "C:\\"
        },
        {
          "name": "-Top",
          "required": false,
          "default": 25
        },
        {
          "name": "-MinSizeMB",
          "required": false,
          "default": 100
        }
      ],
      "title": "Find Large Files"
    },
    {
      "id": "win-clear-temp",
      "path": "windows/Clear-TempFiles.ps1",
      "platform": "windows",
      "category": "storage",
      "summary": "Clean temp folders, WER queue, optionally WU download cache and Recycle Bin. Dry-run unless -Force.",
      "use_when": [
        "free up disk space quickly",
        "before feature update on a full disk"
      ],
      "admin": "optional (Windows temp / WU cache need it)",
      "destructive": true,
      "dry_run_default": true,
      "runtime_seconds": 60,
      "args": [
        {
          "name": "-IncludeWindowsUpdate",
          "required": false
        },
        {
          "name": "-IncludeRecycleBin",
          "required": false
        },
        {
          "name": "-Force",
          "required": false
        }
      ],
      "title": "Clean Temp Files"
    },
    {
      "id": "win-installed-software",
      "path": "windows/Get-InstalledSoftware.ps1",
      "platform": "windows",
      "category": "sysinfo",
      "summary": "Registry-based app inventory (64/32-bit/per-user) with install dates. -SortByDate finds 'what changed last week'.",
      "use_when": [
        "what's installed",
        "did something install right before the problem started",
        "license audit"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 10,
      "args": [
        {
          "name": "-Search",
          "required": false,
          "desc": "name filter"
        },
        {
          "name": "-SortByDate",
          "required": false
        }
      ],
      "title": "Installed Software"
    },
    {
      "id": "win-remove-office365",
      "path": "windows/Remove-Office365.ps1",
      "platform": "windows",
      "category": "repair",
      "title": "Remove Microsoft 365 (Deep)",
      "summary": "Deep uninstall of Microsoft 365/Office: supported uninstall, then removes leftover folders, registry keys, scheduled tasks, and the ClickToRun service a normal uninstall misses; clears cached sign-in/credentials/licensing so products re-authenticate. Never deletes .pst or user docs.",
      "use_when": [
        "office uninstall left files behind",
        "reinstall office clean",
        "office signed into wrong account",
        "office won't activate",
        "office repair failed"
      ],
      "admin": true,
      "destructive": true,
      "dry_run_default": true,
      "runtime_seconds": 300,
      "args": [
        {
          "name": "-Force",
          "required": false,
          "desc": "actually apply; otherwise dry-run preview"
        },
        {
          "name": "-ResetActivationOnly",
          "required": false,
          "desc": "don't uninstall; just clear sign-in/licensing to force re-auth"
        },
        {
          "name": "-RemoveOutlookData",
          "required": false,
          "desc": "also clear Outlook .ost cache (never .pst)"
        }
      ]
    },
    {
      "id": "win-printer-diagnostics",
      "path": "windows/Get-PrinterDiagnostics.ps1",
      "platform": "windows",
      "category": "printing",
      "summary": "Spooler state, printers/ports/drivers, stuck jobs. -ClearQueue purges the queue (admin).",
      "use_when": [
        "can't print",
        "print job stuck",
        "printer offline"
      ],
      "admin": "only for -ClearQueue/-RestartSpooler",
      "destructive": "only with -ClearQueue",
      "runtime_seconds": 15,
      "args": [
        {
          "name": "-ClearQueue",
          "required": false
        },
        {
          "name": "-RestartSpooler",
          "required": false
        }
      ],
      "title": "Printer Diagnostics"
    },
    {
      "id": "win-battery-report",
      "path": "windows/Get-BatteryReport.ps1",
