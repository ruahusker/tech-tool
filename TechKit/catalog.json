      "category": "accounts",
      "summary": "Local users (uid>=500) with admin flag and last login, logged-in users, home sizes (--sizes), hidden/disabled markers.",
      "use_when": [
        "account audit",
        "before user cleanup",
        "who uses this Mac"
      ],
      "admin": false,
      "destructive": false,
      "runtime_seconds": 15,
